{
  "model": "GradientBoostingClassifier",
  "params": {
    "n_estimators": {
      "type": "integer",
      "bounds": [10, 500]
    },
    "learning_rate": {
      "type": "real",
      "bounds": [0.01, 1.0],
      "prior": "log-uniform"
    },
    "max_depth": {
      "type": "integer",
      "bounds": [1, 10]
    },
    "min_samples_split": {
      "type": "integer",
      "bounds": [2, 20]
    },
    "min_samples_leaf": {
      "type": "integer",
      "bounds": [1, 20]
    },
    "subsample": {
      "type": "real",
      "bounds": [0.5, 1.0],
      "prior": "uniform"
    }
  },
  "fixed_params": {
    "random_state": 42
  }
}