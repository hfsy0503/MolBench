{
  "model": "XGBClassifier",
  "params": {
    "n_estimators": {
      "type": "integer",
      "bounds": [100, 1000]
    },
    "max_depth": {
      "type": "integer",
      "bounds": [3, 10]
    },
    "learning_rate": {
      "type": "real",
      "bounds": [0.01, 0.3],
      "prior": "log-uniform"
    },
    "subsample": {
      "type": "real",
      "bounds": [0.6, 1.0]
    },
    "colsample_bytree": {
      "type": "real",
      "bounds": [0.6, 1.0]
    },
    "reg_alpha": {
      "type": "real",
      "bounds": [0.0, 1.0]
    },
    "reg_lambda": {
      "type": "real",
      "bounds": [0.0, 1.0]
    },
    "min_child_weight": {
      "type": "real",
      "bounds": [1e-3, 10.0],
      "prior": "log-uniform"
    }
  },
  "fixed_params": {
    "random_state": 42,
    "n_jobs": -1,
    "tree_method": "hist",
    "eval_metric": "logloss"
  }
}