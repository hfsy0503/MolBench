{
    "model": "DeepChemTextCNN",
    "module": "core.adapters.text_models",
    "task_type": "regression",
    "protocol": "bench",
    "search_space": {
        "lr": {
            "type": "real",
            "bounds": [
                0.0005,
                0.002
            ],
            "prior": "log-uniform"
        },
        "epochs": {
            "type": "integer",
            "bounds": [
                50,
                300
            ]
        },
        "n_embedding": {
            "type": "integer",
