                64,
                256
            ]
        },
        "dropout": {
            "type": "real",
            "bounds": [
                0.2,
                0.5
            ]
        }
    },
    "fixed_params": {
        "model_name": "DeepChem-TextCNN",
        "n_tasks": 1,
        "n_embedding": 128,
        "kernel_sizes": [
            3,
            4,
            5
        ],
        "filter_sizes": [
            100,
            200,
            100
        ],
        "dropout": 0.5,
        "kw": null,
        "model_path": "deepchem-textcnn",
        "lr": 0.001,
        "epochs": 100
    }
