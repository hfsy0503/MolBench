{
    "model": "BenchGNN",
    "module": "molbench.core.adapters.gnn_adapter",
    "task_type": "binary",
    "protocol": "bench",
    "search_space": {
        "lr": {
            "type": "real",
            "bounds": [
                0.0001,
                0.01
            ],
            "prior": "log-uniform"
        },
        "epochs": {
            "type": "integer",
            "bounds": [
                10,
                100
            ]
        },
        "hidden_dim": {
            "type": "integer",
            "bounds": [
                32,
                128
            ]
        },
        "dropout": {
            "type": "real",
            "bounds": [
                0.0,
                0.5
            ]
        }
    },
    "fixed_params": {
        "kw": null,
        "model_name": "GraphSAGE",
        "out_dim": 1,
        "batch_size": 32,
        "aggr": "mean",
        "num_layers": 3,
        "random_state": 42,
        "use_edge_features": false
    }
}