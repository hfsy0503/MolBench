{
  "model": "ElasticNet",
  "params": {
    "alpha": {
      "type": "real",
      "bounds": [0.000001, 1000000.0],
      "prior": "log-uniform"
    },
    "l1_ratio": {
      "type": "real",
      "bounds": [0.0, 1.0]
    },
    "max_iter": {
      "type": "integer",
      "bounds": [100, 1000]
    }
  },
  "fixed_params": {
    "random_state": 42
  }
}