{
  "model": "GaussianProcessRegressor",
  "params": {
    "alpha": {
      "type": "real",
      "bounds": [0.000001, 0.1],
      "prior": "log-uniform"
    },
    "n_restarts_optimizer": {
      "type": "integer",
      "bounds": [5, 15]
    },
    "normalize_y": {
      "type": "categorical",
      "categories": [true, false]
    }
  },
  "fixed_params": {
    "random_state": 42,
    "n_restarts_optimizer": 10,
    "kernel": "ConstantKernel(1.0) * RBF(1.0) + WhiteKernel(1e-5)"
  }
}